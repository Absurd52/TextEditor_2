<Window x:Class="TextEditorWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Текстовый редактор" 
        Height="800" Width="1200" MinHeight="600" MinWidth="800"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Стиль для кнопок панели инструментов с иконками -->
        <Style x:Key="ToolBarButtonWithIcon" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="ToolTipService.ShowDuration" Value="5000"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFE5F1FB"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="BorderBrush" Value="#FF0078D7"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FFCCE4F7"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="BorderBrush" Value="#FF005499"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для пунктов меню (теперь БЕЗ иконок) -->
        <Style x:Key="MenuItemWithIcon" TargetType="MenuItem">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- Иконки с использованием Segoe MDL2 Assets (нужны Toolbar/StatusBar) -->
        <Style x:Key="IconTextBlock" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <!-- ===== ГЛАВНОЕ МЕНЮ ===== -->
        <Menu DockPanel.Dock="Top" Height="24" FontSize="14" Background="#F0F0F0">
            <!-- Файл -->
            <MenuItem Header="_Файл">
                <MenuItem x:Name="NewMenuItem" Header="_Создать" InputGestureText="Ctrl+N" 
                          Style="{StaticResource MenuItemWithIcon}" Click="NewMenuItem_Click"/>
                <MenuItem x:Name="OpenMenuItem" Header="_Открыть" InputGestureText="Ctrl+O" 
                          Style="{StaticResource MenuItemWithIcon}" Click="OpenMenuItem_Click"/>
                <MenuItem x:Name="SaveMenuItem" Header="_Сохранить" InputGestureText="Ctrl+S" 
                          Style="{StaticResource MenuItemWithIcon}" Click="SaveMenuItem_Click"/>
                <MenuItem x:Name="SaveAsMenuItem" Header="Сохранить _как" InputGestureText="Ctrl+Shift+S" 
                          Style="{StaticResource MenuItemWithIcon}" Click="SaveAsMenuItem_Click"/>
                <Separator/>
                <MenuItem x:Name="ExitMenuItem" Header="В_ыход" InputGestureText="Alt+F4" 
                          Style="{StaticResource MenuItemWithIcon}" Click="ExitMenuItem_Click"/>
            </MenuItem>

            <!-- Правка -->
            <MenuItem Header="_Правка">
                <MenuItem x:Name="UndoMenuItem" Header="_Отменить" InputGestureText="Ctrl+Z" 
                          Style="{StaticResource MenuItemWithIcon}" Click="UndoMenuItem_Click"/>
                <MenuItem x:Name="RedoMenuItem" Header="_Повторить" InputGestureText="Ctrl+Y" 
                          Style="{StaticResource MenuItemWithIcon}" Click="RedoMenuItem_Click"/>
                <Separator/>
                <MenuItem x:Name="CutMenuItem" Header="Вы_резать" InputGestureText="Ctrl+X" 
                          Style="{StaticResource MenuItemWithIcon}" Click="CutMenuItem_Click"/>
                <MenuItem x:Name="CopyMenuItem" Header="_Копировать" InputGestureText="Ctrl+C" 
                          Style="{StaticResource MenuItemWithIcon}" Click="CopyMenuItem_Click"/>
                <MenuItem x:Name="PasteMenuItem" Header="_Вставить" InputGestureText="Ctrl+V" 
                          Style="{StaticResource MenuItemWithIcon}" Click="PasteMenuItem_Click"/>
                <MenuItem x:Name="DeleteMenuItem" Header="_Удалить" InputGestureText="Del" 
                          Style="{StaticResource MenuItemWithIcon}" Click="DeleteMenuItem_Click"/>
                <Separator/>
                <MenuItem x:Name="SelectAllMenuItem" Header="Выделить _все" InputGestureText="Ctrl+A" 
                          Style="{StaticResource MenuItemWithIcon}" Click="SelectAllMenuItem_Click"/>
            </MenuItem>

            <!-- Текст -->
            <MenuItem Header="_Текст">
                <MenuItem x:Name="TaskMenuItem" Header="Постановка задачи" Click="TextMenuItem_Click"/>
                <MenuItem x:Name="GrammarMenuItem" Header="Грамматика" Click="TextMenuItem_Click"/>
                <MenuItem x:Name="GrammarClassMenuItem" Header="Классификация грамматики" Click="TextMenuItem_Click"/>
                <MenuItem x:Name="MethodMenuItem" Header="Метод анализа" Click="TextMenuItem_Click"/>
                <MenuItem x:Name="TestMenuItem" Header="Тестовый пример" Click="TextMenuItem_Click"/>
                <MenuItem x:Name="LiteratureMenuItem" Header="Список литературы" Click="TextMenuItem_Click"/>
                <MenuItem x:Name="SourceCodeMenuItem" Header="Исходный код программы" Click="TextMenuItem_Click"/>
            </MenuItem>

            <!-- Пуск -->
            <MenuItem x:Name="StartMenuItem" Header="_Пуск">
                <MenuItem x:Name="RunAnalyzerMenuItem" Header="Запуск анализатора" Click="RunAnalyzerMenuItem_Click"/>
            </MenuItem>

            <!-- Справка -->
            <MenuItem Header="_Справка">
                <MenuItem x:Name="HelpMenuItem" Header="Вызов _справки" InputGestureText="F1" Click="HelpMenuItem_Click"/>
                <MenuItem x:Name="AboutMenuItem" Header="_О программе" Click="AboutMenuItem_Click"/>
            </MenuItem>
        </Menu>

        <!-- ===== ПАНЕЛЬ ИНСТРУМЕНТОВ С ИКОНКАМИ ===== -->
        <!-- ===== ПАНЕЛЬ ИНСТРУМЕНТОВ (РОВНО, БЕЗ ЛИНИЙ, РАВНОМЕРНО ПО ШИРИНЕ) ===== -->
        <ToolBarTray DockPanel.Dock="Top" Background="White">
            <ToolBar Height="64" Background="White" BorderThickness="0">

                <!-- ВАЖНО: в шаблоне должен быть ItemsPresenter -->
                <ToolBar.Template>
                    <ControlTemplate TargetType="{x:Type ToolBar}">
                        <Border Background="{TemplateBinding Background}"
                        Padding="8,6"
                        SnapsToDevicePixels="True">
                            <ItemsPresenter/>
                        </Border>
                    </ControlTemplate>
                </ToolBar.Template>

                <!-- Равномерное распределение по ширине -->
                <ToolBar.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1" Columns="11"/>
                    </ItemsPanelTemplate>
                </ToolBar.ItemsPanel>

                <!-- Кнопки -->
                <Button x:Name="NewButton" Style="{StaticResource ToolBarButtonWithIcon}" Click="NewMenuItem_Click" ToolTip="Создать (Ctrl+N)">
                    <TextBlock Style="{StaticResource IconTextBlock}" Text="&#xE710;" FontSize="20"/>
                </Button>

                <Button x:Name="OpenButton" Style="{StaticResource ToolBarButtonWithIcon}" Click="OpenMenuItem_Click" ToolTip="Открыть (Ctrl+O)">
                    <TextBlock Style="{StaticResource IconTextBlock}" Text="&#xE8E5;" FontSize="20"/>
                </Button>

                <Button x:Name="SaveButton" Style="{StaticResource ToolBarButtonWithIcon}" Click="SaveMenuItem_Click" ToolTip="Сохранить (Ctrl+S)">
                    <TextBlock Style="{StaticResource IconTextBlock}" Text="&#xE74E;" FontSize="20"/>
                </Button>

                <Button x:Name="UndoButton" Style="{StaticResource ToolBarButtonWithIcon}" Click="UndoMenuItem_Click" ToolTip="Отменить (Ctrl+Z)">
                    <TextBlock Style="{StaticResource IconTextBlock}" Text="&#xE7A7;" FontSize="20"/>
                </Button>

                <Button x:Name="RedoButton" Style="{StaticResource ToolBarButtonWithIcon}" Click="RedoMenuItem_Click" ToolTip="Повторить (Ctrl+Y)">
                    <TextBlock Style="{StaticResource IconTextBlock}" Text="&#xE7A6;" FontSize="20"/>
                </Button>

                <Button x:Name="CutButton" Style="{StaticResource ToolBarButtonWithIcon}" Click="CutMenuItem_Click" ToolTip="Вырезать (Ctrl+X)">
                    <TextBlock Style="{StaticResource IconTextBlock}" Text="&#xE8C6;" FontSize="20"/>
                </Button>

                <Button x:Name="CopyButton" Style="{StaticResource ToolBarButtonWithIcon}" Click="CopyMenuItem_Click" ToolTip="Копировать (Ctrl+C)">
                    <TextBlock Style="{StaticResource IconTextBlock}" Text="&#xE8C8;" FontSize="20"/>
                </Button>

                <Button x:Name="PasteButton" Style="{StaticResource ToolBarButtonWithIcon}" Click="PasteMenuItem_Click" ToolTip="Вставить (Ctrl+V)">
                    <TextBlock Style="{StaticResource IconTextBlock}" Text="&#xE77F;" FontSize="20"/>
                </Button>

                <Button x:Name="AnalyzeButton" Style="{StaticResource ToolBarButtonWithIcon}" Click="RunAnalyzerMenuItem_Click" ToolTip="Запуск анализатора">
                    <TextBlock Style="{StaticResource IconTextBlock}" Text="&#xE768;" FontSize="20"/>
                </Button>

                <Button x:Name="HelpButton" Style="{StaticResource ToolBarButtonWithIcon}" Click="HelpMenuItem_Click" ToolTip="Справка (F1)">
                    <TextBlock Style="{StaticResource IconTextBlock}" Text="&#xE897;" FontSize="20"/>
                </Button>

                <Button x:Name="AboutButton" Style="{StaticResource ToolBarButtonWithIcon}" Click="AboutMenuItem_Click" ToolTip="О программе">
                    <TextBlock Style="{StaticResource IconTextBlock}" Text="&#xE946;" FontSize="20"/>
                </Button>

            </ToolBar>
        </ToolBarTray>

        <!-- ===== СТРОКА СОСТОЯНИЯ ===== -->
        <StatusBar DockPanel.Dock="Bottom" Height="28" Background="#F0F0F0">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Style="{StaticResource IconTextBlock}" Text="&#xE946;" FontSize="14" Margin="0,0,5,0"/>
                    <TextBlock x:Name="StatusTextBlock" Text="Готов" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="FileInfoTextBox" Text="" FontSize="12" VerticalAlignment="Center"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ===== ОСНОВНОЙ КОНТЕЙНЕР С ИЗМЕНЯЕМЫМИ ОБЛАСТЯМИ ===== -->
        <Grid Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <GroupBox Grid.Row="0" Header="Область редактирования" FontWeight="Bold" Padding="5">
                <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="3">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <TextBox x:Name="EditorTextBox" 
                                FontFamily="Consolas" 
                                FontSize="12"
                                AcceptsTab="True"
                                AcceptsReturn="True"
                                TextWrapping="Wrap"
                                VerticalScrollBarVisibility="Auto"
                                HorizontalScrollBarVisibility="Auto"
                                Background="White"
                                Foreground="Black"
                                Padding="5"
                                BorderThickness="0"
                                TextChanged="EditorTextBox_TextChanged"/>
                    </ScrollViewer>
                </Border>
            </GroupBox>

            <GridSplitter Grid.Row="1" 
                         Height="5" 
                         HorizontalAlignment="Stretch" 
                         VerticalAlignment="Center" 
                         ShowsPreview="True"
                         Background="#FF0078D7"
                         Margin="5,0"/>

            <GroupBox Grid.Row="2" Header="Область отображения результатов" FontWeight="Bold" Padding="5">
                <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="3">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <TextBox x:Name="ResultAreaTextBox" 
                                FontFamily="Consolas" 
                                FontSize="12"
                                IsReadOnly="True"
                                TextWrapping="Wrap"
                                VerticalScrollBarVisibility="Auto"
                                HorizontalScrollBarVisibility="Auto"
                                Background="#F9F9F9"
                                Foreground="#333333"
                                Padding="5"
                                BorderThickness="0"
                                Text="Результаты работы языкового процессора..."/>
                    </ScrollViewer>
                </Border>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>